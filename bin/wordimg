#!/usr/bin/env bash

# ========================================
# wordimg - Extract and resize images from Word documents
# ========================================

set -e

# -------- Colors --------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RESET='\033[0m'

# -------- Dependency Checks --------
require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo -e "${RED}✗ '$1' is required but not installed.${RESET}"
    echo "  → On macOS: brew install $1"
    echo "  → On Debian/Ubuntu: sudo apt install $1"
    exit 1
  fi
}

require_command magick
require_command unzip

# -------- Defaults --------
SIZE="1024"
BG="white"
FIT="contain"
KEEP=false

# -------- Usage --------
usage() {
  echo -e "${BLUE}Usage:${RESET}"
  echo "  wordimg --file FILE --output DIR [--size SIZE|WxH] [--background COLOR] [--fit contain|cover] [--keep]"
  echo ""
  echo -e "${BLUE}Options:${RESET}"
  echo "  --file       Source .docx file"
  echo "  --output     Output directory"
  echo "  --size       Target dimension in pixels. Single number for square (default: 1024) or WxH for custom size (e.g., 1000x500)"
  echo "  --background Background color (default: white, use 'none' for transparency)"
  echo "  --fit        Resize mode: contain (default) or cover"
  echo "  --keep       Keep original extracted images in a _originals subfolder"
  echo "  --help       Show this help message"
  exit 1
}

# -------- Parse Arguments --------
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --file) FILE="$2"; shift ;;
    --output) OUTDIR="$2"; shift ;;
    --size) SIZE="$2"; shift ;;
    --background) BG="$2"; shift ;;
    --fit) FIT="$2"; shift ;;
    --keep) KEEP=true ;;
    --help) usage ;;
    *) echo -e "${RED}✗ Unknown option: $1${RESET}"; usage ;;
  esac
  shift
done

# -------- Validate Inputs --------
[[ -z "$FILE" || -z "$OUTDIR" ]] && usage

if [[ ! -f "$FILE" || "${FILE##*.}" != "docx" ]]; then
  echo -e "${RED}✗ File does not exist or is not a .docx${RESET}"
  exit 1
fi

if [[ "$FIT" != "contain" && "$FIT" != "cover" ]]; then
  echo -e "${RED}✗ Fit must be 'contain' or 'cover'.${RESET}"
  exit 1
fi

# -------- Parse SIZE for square or WxH --------
if [[ "$SIZE" =~ ^[0-9]+$ ]]; then
  WIDTH="$SIZE"
  HEIGHT="$SIZE"
elif [[ "$SIZE" =~ ^([0-9]+)x([0-9]+)$ ]]; then
  WIDTH="${BASH_REMATCH[1]}"
  HEIGHT="${BASH_REMATCH[2]}"
else
  echo -e "${RED}✗ Invalid size format. Use a single number or WxH (e.g., 1000 or 1000x500).${RESET}"
  exit 1
fi

# -------- Ensure Output Directory --------
mkdir -p "$OUTDIR" || { echo -e "${RED}✗ Cannot create output directory $OUTDIR${RESET}"; exit 1; }

# -------- Spinner Function (simplified) --------
spinner() {
  local pid=$1
  local delay=0.1
  local spinstr='|/-\'
  tput civis
  while kill -0 "$pid" 2>/dev/null; do
    for ((i=0; i<${#spinstr}; i++)); do
      printf "\r→ %c" "${spinstr:i:1}"
      sleep $delay
    done
  done
  tput cnorm
  printf "\r"
}

# -------- Temp Folder --------
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# -------- Step 1: Extract Images --------
echo -e "→ Extracting images from ${FILE}..."
if ! unzip -j "$FILE" "word/media/*" -d "$TMPDIR" >/dev/null; then
  echo -e "${RED}✗ Failed to extract images. Check that the .docx exists and is valid.${RESET}"
  exit 1
fi
echo -e "${GREEN}✓ Images extracted to temporary folder${RESET}"

# -------- Save Originals if --keep --------
if [ "$KEEP" = true ]; then
  mkdir -p "$OUTDIR/_originals"
  cp "$TMPDIR"/* "$OUTDIR/_originals"/
  echo -e "→ Originals saved to ${OUTDIR}/_originals"
fi

# -------- Step 2: Convert Images --------
resize_flag=""
if [[ "$FIT" == "cover" ]]; then
  resize_flag="^"
fi

echo -e "→ Converting images to target dimensions ${WIDTH}x${HEIGHT} with fit=${FIT}..."

# Use find + xargs to handle filenames safely (compatible with macOS bash)
find "$TMPDIR" -type f -print0 | xargs -0 magick mogrify \
  -path "$OUTDIR" \
  -resize "${WIDTH}x${HEIGHT}${resize_flag}" \
  -background "$BG" \
  -gravity center \
  -extent "${WIDTH}x${HEIGHT}" &

pid=$!
spinner $pid
wait $pid

echo -e "${GREEN}✓ Images resized and saved to ${OUTDIR}${RESET}"
echo -e "${GREEN}✓ Done.${RESET}"